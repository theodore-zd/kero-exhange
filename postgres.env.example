# PostgreSQL Configuration Example
# Copy this file to postgres.env and update values

# Container Configuration (for local development)
CONTAINER_NAME=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=local_pg
POSTGRES_PORT=5433
DATA_DIR=./_local_deploy/.postgres/data

# Database Connection String for Backend
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?sslmode=disable
# Password should be URL-encoded if it contains special characters (@, :, #, %, etc.)
# For development: sslmode=disable (containers don't have SSL)
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5433/local_pg?sslmode=disable

# Goose Database Migrations (for CLI usage)
# Use with goose CLI: goose -dir ./migrations postgres "$DATABASE_URL" up
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=$DATABASE_URL
GOOSE_MIGRATION_DIR=./migrations
