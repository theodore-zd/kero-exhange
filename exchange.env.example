# Exchange Server Configuration

# Server port (default: 8090)
PORT=8090

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Admin password for admin UI access (required)
ADMIN_PASSWORD=changeme

# Default currency settings
# DEFAULT_CURRENCY_CODE=USD (default)
# DEFAULT_CURRENCY_NAME=US Dollar (default)
# DEFAULT_CURRENCY_DESCRIPTION=Primary currency for the exchange (optional)
